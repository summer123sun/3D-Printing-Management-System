# =====================================================
# 根目录 .gitignore（3D 打印科创会管理系统）
# =====================================================

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# 操作系统临时
$RECYCLE.BIN/

# 前端 / 后端各自的 .gitignore 会处理更细的规则
vue-3d/.env.local
vue-3d/.env.*.local
spring-boot-backend/src/main/resources/application-local.yml

# 不提交任何含真实密码的配置
*.secret
*.private

# ============================================
# 兜底规则（各子项目 .gitignore 之外的）
# ============================================

# 后端运行时：占位图（commit 到 git，组员拉下来就有）
# 屏蔽 classpath 占位图目录，但留 placeholder.png 作为缺图回退
spring-boot-backend/src/main/resources/static/uploads/
!spring-boot-backend/src/main/resources/static/placeholder.png

# 后端运行时上传目录
# 重要：不要在根 .gitignore 写 `uploads/` 全屏蔽 + `!uploads/preview/` 否定，
#      git 优先级让否定规则被忽略。占位图 / 用户上传的精细规则
#      全部放在 spring-boot-backend/.gitignore 里。
# （这里留空，避免误屏蔽占位图）

# MySQL 客户端 tee 输出残留
query
*.query
tee.out

# 临时/备份
*.bak
*.tmp
*.swp
*~
*.orig
*.rej
