# =====================================================
# Spring Boot 后端 .gitignore
# =====================================================

# Maven 构建产物
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

### Maven
mvnw
mvnw.cmd
.mvn/

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.classpath
.project
.settings/
.factorypath
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/
build/
nb-configuration.xml

# 日志
*.log
logs/
spring-boot-backend.log

# 临时文件
*.tmp
*.bak
*.swp

# 系统
.DS_Store
Thumbs.db

# 敏感信息（绝对不要提交）
src/main/resources/application-local.yml
# 注意：application.yml / application-dev.yml / application-prod.yml 提交到仓库
# 这三个文件不含真实密码（用 ${DB_PASSWORD:root} 占位符）

# 编译 class
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*

# 测试覆盖率报告
jacoco.exec
test-output/
surefire-reports/

# 上传文件目录（占位图保留，用户上传的屏蔽）
# 占位图（commit 到 git，组员拉下来就有，不屏蔽）
# 注释：不要写 uploads/ 全屏蔽 + !uploads/preview/ 这种否定规则，
#      git 优先级让否定规则被忽略。直接只屏蔽用户上传的子目录。
#
# 用户上传的实际文件（运行时产生，不提交）
# 命名约定：占位文件直接放在 uploads/ 子目录（commit 到 git），
#           用户上传的同名文件会覆盖占位（同名场景极少，且覆盖空占位无害）。
# img/ 和 avatar/ 都是图片（运行时上传的）
uploads/img/
uploads/img/**
uploads/file/
uploads/file/**
uploads/avatar/
uploads/avatar/**
# STL 不屏蔽：占位文件 commit 到 git（让组员拉代码就有 STL 3D 模型）

# classpath 静态资源
src/main/resources/static/uploads/
!src/main/resources/static/placeholder.png

# Vue 临时缓存
*.local
